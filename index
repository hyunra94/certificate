<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>수료증 조회</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Apple SD Gothic Neo', 'Pretendard', sans-serif;
      background: #f5f7fa;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 20px;
    }
    .card {
      background: white;
      border-radius: 16px;
      padding: 40px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    h1 { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
    .sub { color: #888; font-size: 14px; margin-bottom: 32px; line-height: 1.5; }
    label { font-size: 13px; font-weight: 600; color: #444; display: block; margin-bottom: 6px; }
    input {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid #e0e0e0;
      border-radius: 10px;
      font-size: 15px;
      margin-bottom: 16px;
      outline: none;
      transition: border 0.2s;
    }
    input:focus { border-color: #4f46e5; }
    button {
      width: 100%;
      padding: 14px;
      background: #4f46e5;
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
      margin-bottom: 8px;
    }
    button:hover  { background: #4338ca; }
    button:disabled { background: #a5b4fc; cursor: not-allowed; }
    .notice {
      font-size: 12px;
      color: #aaa;
      text-align: center;
      margin-bottom: 0;
    }
    #result { margin-top: 24px; }
    .success {
      background: #f0fdf4;
      border: 1.5px solid #86efac;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
    }
    .success .cert-course { font-size: 17px; font-weight: 700; margin-bottom: 4px; }
    .success .cert-date   { font-size: 13px; color: #666; margin-bottom: 16px; }
    .download-btn {
      display: inline-block;
      padding: 10px 28px;
      background: #16a34a;
      color: white;
      border-radius: 8px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
    }
    .error {
      background: #fff5f5;
      border: 1.5px solid #fca5a5;
      border-radius: 12px;
      padding: 16px;
      color: #dc2626;
      font-size: 14px;
      text-align: center;
      line-height: 1.6;
    }
    .loading { text-align: center; color: #888; font-size: 14px; padding: 16px; }
  </style>
</head>
<body>
<div class="card">
  <h1>📄 수료증 조회</h1>
  <p class="sub">이름과 생년월일을 입력하면<br>수료증을 다운로드할 수 있습니다.</p>

  <label>이름</label>
  <input type="text" id="name" placeholder="홍길동" maxlength="10" autocomplete="off">

  <label>생년월일</label>
  <input type="text" id="birth" placeholder="19900101 (숫자 8자리)" maxlength="8"
         inputmode="numeric" autocomplete="off">

  <button id="searchBtn" onclick="search()">조회하기</button>
  <p class="notice">🔒 입력하신 정보는 저장되지 않습니다.</p>

  <div id="result"></div>
</div>

<script>
  // ← Cloudflare Workers URL만 있으면 됨 (API 키 없음)
  const WORKER_URL = 'https://certificate-api.abyss9405.workers.dev';

  // 조회 횟수 제한 (같은 브라우저에서 1분에 5회)
  const attempts = [];
  function isRateLimited() {
    const now = Date.now();
    const recent = attempts.filter(t => now - t < 60000);
    attempts.length = 0;
    recent.forEach(t => attempts.push(t));
    if (recent.length >= 5) return true;
    attempts.push(now);
    return false;
  }

  async function search() {
    const name  = document.getElementById('name').value.trim();
    const birth = document.getElementById('birth').value.trim();
    const result = document.getElementById('result');
    const btn   = document.getElementById('searchBtn');

    if (!name || !birth) {
      result.innerHTML = '<div class="error">이름과 생년월일을 모두 입력해주세요.</div>';
      return;
    }

    if (isRateLimited()) {
      result.innerHTML = '<div class="error">잠시 후 다시 시도해주세요.<br>(1분에 최대 5회 조회 가능)</div>';
      return;
    }

    btn.disabled = true;
    btn.textContent = '조회 중...';
    result.innerHTML = '<div class="loading">🔍 조회 중입니다...</div>';

    try {
      const res  = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, birth })
      });

      const data = await res.json();

      if (data.found) {
        result.innerHTML = `
          <div class="success">
            <div class="cert-course">🎓 ${data.course}</div>
            <div class="cert-date">수료일: ${data.date}</div>
            <a class="download-btn" href="${data.certUrl}" target="_blank" rel="noopener">
              📥 수료증 다운로드
            </a>
          </div>`;
      } else {
        // 없을 때도 구체적 이유 안 알려줌 (열거 공격 방지)
        result.innerHTML = `
          <div class="error">
            수료증 정보를 찾을 수 없습니다.<br>
            이름 또는 생년월일을 다시 확인해주세요.
          </div>`;
      }

    } catch {
      result.innerHTML = '<div class="error">오류가 발생했습니다. 잠시 후 다시 시도해주세요.</div>';
    }

    btn.disabled = false;
    btn.textContent = '조회하기';
  }

  // 엔터키 지원
  document.addEventListener('keydown', e => {
    if (e.key === 'Enter') search();
  });
</script>
</body>
</html>
